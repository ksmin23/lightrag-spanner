# Google Cloud Settings
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=your-gcp-location

# Google Cloud Spanner configuration
SPANNER_INSTANCE=your-spanner-instance
SPANNER_DATABASE=your-spanner-database
SPANNER_GRAPH_NAME=lightrag_test_knowledge_graph

# LLM configuration
# Option A: Gemini via Vertex AI (uses Application Default Credentials)
GOOGLE_GENAI_USE_VERTEXAI=true
# Option B: Gemini via AI Studio (uses API key)
# GEMINI_API_KEY=your-gemini-api-key
# Option C: OpenAI
# OPENAI_API_KEY=your-openai-api-key

# Optional: override default model settings
LLM_MODEL_NAME=gemini-2.5-flash
EMBEDDING_MODEL_NAME=gemini-embedding-001
EMBEDDING_DIM=1536
EMBEDDING_MAX_TOKEN_SIZE=2048